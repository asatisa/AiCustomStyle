{
  "manifest_version": 3,
  "name": "AI Custom Style",
  "version": "1.1.0",
  "description": "Maximize chat width for Gemini, Claude, and ChatGPT.",
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*"
      ],
      "css": ["content.css"]
    }
  ]
}